// packetdrill regression test for FreeBSD bug 296594 -- fix #1 (reset test).
//
// RFC 5961 3.2: a RST with SEG.SEQ == RCV.NXT MUST reset the connection.
// tcp_do_segment() runs the exact-match reset test against last_ack_sent, not
// rcv_nxt. When the receiver has delayed-ACKed the preceding data
// (RCV.NXT > last_ack_sent), a valid RST at RCV.NXT is in-window but not an
// exact match, so the stock kernel answers with a challenge ACK and leaves the
// connection ESTABLISHED (half-open).
//
// PASS (patched): the RST resets the connection -- no packet is sent in
//   response; the buffered data drains, then read() reports ECONNRESET.
// FAIL (stock):   the kernel emits an unscripted challenge ACK (> . ack 1001)
//   and the connection stays up -- packetdrill flags the stray packet.

`sysctl -q net.inet.tcp.insecure_rst=0 net.inet.tcp.delayed_ack=1`

// --- establish a connection; the local (kernel-under-test) end is passive ---
    0 socket(..., SOCK_STREAM, IPPROTO_TCP) = 3
   +0 setsockopt(3, SOL_SOCKET, SO_REUSEADDR, [1], 4) = 0
   +0 bind(3, ..., ...) = 0
   +0 listen(3, 1) = 0

   +0 < S 0:0(0) win 65535 <mss 1460,sackOK,nop,nop,nop,wscale 7>
   +0 > S. 0:0(0) ack 1 win 65535 <mss 1460,nop,wscale 8,sackOK,eol,eol>
  +.1 < . 1:1(0) ack 1 win 65535
   +0 accept(3, ..., ...) = 4
   +0 fcntl(4, F_SETFL, O_RDWR|O_NONBLOCK) = 0

// --- create the delayed-ACK gap ---
// One in-order data segment (< 2*MSS, so it is delay-ACKed): RCV.NXT advances
// to 1001 while last_ack_sent stays 1. No ACK is emitted at +0.
   +0 < P. 1:1001(1000) ack 1 win 65535

// --- the valid RST at RCV.NXT ---
// Peer abortively closes: RST, seq == RCV.NXT (1001), in-window. MUST reset.
   +0 < R. 1001:1001(0) ack 1 win 65535

// --- assert the reset, with no packet sent in response ---
   +0 read(4, ..., 1000) = 1000                                   // buffered data drains first
   +0 read(4, ..., 1000) = -1 ECONNRESET (Connection reset by peer)
